            <!-- Alt_bn128 elliptic curve -->
            <symbol name="sol_alt_bn128_group_op" address="syscall:0xae0c318b"/>
            <symbol name="sol_alt_bn128_compression" address="syscall:0x334fd5ed"/>

            <!-- Big modular exponentiation -->
            <symbol name="sol_big_mod_exp" address="syscall:0x780e4c15"/>

            <!-- Epoch stake -->
            <symbol name="sol_get_epoch_stake" address="syscall:0x5be92f4a"/>

            <!-- Memory allocator (deprecated) -->
            <symbol name="sol_alloc_free_" address="syscall:0x83f00e8f"/>
    </default_symbols>
    <default_memory_blocks>
        <memory_block name="Solana_syscalls_low" start_address="syscall:0x00000000" length="0x7fffffff" initialized="false"/>
        <memory_block name="Solana_syscalls_high" start_address="syscall:0x80000000" length="0x7fffffff" initialized="false"/>
    </default_memory_blocks>
</processor_spec>
